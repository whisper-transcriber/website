---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const steps = [
  {
    number: '01',
    title: t('how.step1.title'),
    description: t('how.step1.desc'),
  },
  {
    number: '02',
    title: t('how.step2.title'),
    description: t('how.step2.desc'),
  },
  {
    number: '03',
    title: t('how.step3.title'),
    description: t('how.step3.desc'),
  },
]
---

<section id="how-it-works" class="py-20 lg:py-32 bg-cream-100">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-16 lg:mb-24">
      <h2
        class="text-4xl md:text-5xl lg:text-7xl font-black text-brand-dark mb-6 tracking-tight"
        set:html={t('how.title')}
      >
      </h2>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-12 sm:gap-8 md:gap-12"
    >
      {
        steps.map((step) => (
          <div class="relative group mt-8 sm:mt-0">
            <div class="text-7xl lg:text-8xl font-black text-brand-dark/5 absolute -top-10 lg:-top-12 -left-2 lg:-left-4 group-hover:text-brand-dark/10 transition-colors duration-500">
              {step.number}
            </div>
            <div class="relative pt-6 lg:pt-8">
              <h3 class="text-2xl lg:text-3xl font-black text-brand-dark mb-4 lg:mb-6 tracking-tight">
                {step.title}
              </h3>
              <p class="text-lg lg:text-xl text-brand-dark/60 font-medium leading-relaxed">
                {step.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

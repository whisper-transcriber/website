---
import Layout from '../layouts/Layout.astro'
import Footer from './Footer.astro'
import DownloadButton from './DownloadButton.astro'
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const homeUrl = lang === 'br' ? '/br' : '/'
---

<Layout title={`${t('thankyou.title')} - Whisper Transcriber`}>
  <header class="bg-cream-100">
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center">
      <a href={homeUrl} class="flex items-center gap-2 group">
        <div
          class="w-8 h-8 flex items-center justify-center transition-transform group-hover:scale-105"
        >
          <img
            src="/icon.png"
            alt="Whisper Transcriber Icon"
            class="w-full h-full object-contain mix-blend-multiply"
          />
        </div>
        <span class="text-lg font-bold tracking-tight text-brand-dark"
          >Whisper<span class="text-brand-dark/70">Transcriber</span>
        </span>
      </a>
    </div>
  </header>

  <main class="bg-cream-50">
    <section class="py-6 sm:py-10 lg:py-14">
      <div class="max-w-lg mx-auto px-6 text-center">
        <!-- Success icon -->
        <div
          class="w-12 h-12 mx-auto mb-3 rounded-full bg-brand-accent flex items-center justify-center"
        >
          <svg
            class="w-6 h-6 text-brand-dark"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M5 13l4 4L19 7"></path>
          </svg>
        </div>

        <h1
          class="text-3xl md:text-5xl font-black tracking-tight text-brand-dark mb-1"
        >
          {t('thankyou.title')}
        </h1>

        <p class="text-base md:text-lg text-brand-dark/70 font-medium mb-5 sm:mb-8">
          {t('thankyou.subtitle')}
        </p>

        <!-- Single card: email + steps -->
        <div class="clean-card p-4 sm:p-6 mb-5 sm:mb-8 text-left">
          <!-- Check email -->
          <div class="flex items-start gap-3 mb-3 pb-3 sm:mb-5 sm:pb-5 border-b border-brand-dark/5">
            <div
              class="w-8 h-8 rounded-lg bg-cream-100 flex items-center justify-center shrink-0 mt-0.5"
            >
              <svg
                class="w-4 h-4 text-brand-dark/70"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <div>
              <h2 class="text-sm font-bold text-brand-dark mb-0.5">
                {t('thankyou.checkEmail')}
              </h2>
              <p
                class="text-brand-dark/60 text-xs leading-relaxed"
                set:html={t('thankyou.checkEmailDesc')}
              />
              <p class="text-brand-dark/40 text-[11px] mt-1">
                {t('thankyou.checkSpam')}
              </p>
            </div>
          </div>

          <!-- Next steps -->
          <h2 class="text-sm font-bold text-brand-dark mb-2 sm:mb-3">
            {t('thankyou.nextSteps')}
          </h2>
          <ol class="space-y-2">
            {
              [
                t('thankyou.step1'),
                t('thankyou.step2'),
                t('thankyou.step3'),
              ].map((step, i) => (
                <li class="flex items-center gap-3">
                  <span class="w-6 h-6 rounded-full bg-brand-dark text-white text-xs font-bold flex items-center justify-center shrink-0">
                    {i + 1}
                  </span>
                  <span
                    class="text-brand-dark/70 text-sm"
                    set:html={step}
                  />
                </li>
              ))
            }
          </ol>
        </div>

        <!-- Download -->
        <div class="flex justify-center mb-4">
          <DownloadButton
            label={t('thankyou.download')}
            href="https://api.whispertranscriber.com/download"
            iosShareLabel={t('thankyou.iosShareBtn')}
            iosShareText={t('thankyou.iosShareText')}
          />
        </div>

        <p class="text-xs text-brand-dark/40 pb-6 sm:pb-0">
          {t('thankyou.help')}
          <a
            href="mailto:help@whispertranscriber.com"
            class="text-brand-dark/60 underline hover:text-brand-dark transition-colors"
            >help@whispertranscriber.com</a
          >
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

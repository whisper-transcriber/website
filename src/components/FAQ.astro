---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const faqs = [
  {
    question: t('faq.q1'),
    answer: t('faq.a1'),
  },
  {
    question: t('faq.q2'),
    answer: t('faq.a2'),
  },
  {
    question: t('faq.q3'),
    answer: t('faq.a3'),
  },
  {
    question: t('faq.q4'),
    answer: t('faq.a4'),
  },
  {
    question: t('faq.q5'),
    answer: t('faq.a5'),
  },
  {
    question: t('faq.q6'),
    answer: t('faq.a6'),
  },
]
---

<section id="faq" class="py-20 lg:py-32 bg-[#FAF9F6]">
  <div class="max-w-4xl mx-auto px-6">
    <div class="mb-16 lg:mb-24">
      <h2
        class="text-4xl md:text-5xl lg:text-7xl font-black text-[#2C2C2E] mb-6 md:mb-8 tracking-tight"
        set:html={t('faq.title')}
      >
      </h2>
    </div>

    <div class="space-y-12">
      {
        faqs.map((faq) => (
          <div class="group">
            <h3 class="text-2xl font-black text-[#2C2C2E] mb-4 tracking-tight group-hover:text-[#2C2C2E]/60 transition-colors cursor-pointer">
              {faq.question}
            </h3>
            <p class="text-[#2C2C2E]/60 font-medium leading-relaxed max-w-3xl">
              {faq.answer}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Support Section -->
    <div
      class="mt-20 lg:mt-40 p-8 lg:p-12 bg-[#F2F0EA] rounded-[2rem] lg:rounded-[2.5rem] border border-[#2C2C2E]/5 text-center"
    >
      <h3
        class="text-2xl lg:text-3xl font-black text-[#2C2C2E] mb-4 lg:mb-6 tracking-tight"
      >
        {t('faq.support.title')}
      </h3>
      <p
        class="text-[#2C2C2E]/60 font-medium mb-8 lg:mb-10 text-sm lg:text-base"
      >
        {t('faq.support.desc')}
      </p>
      <a
        href="mailto:help@whispertranscriber.com"
        class="text-lg lg:text-xl font-black text-[#2C2C2E] underline underline-offset-8 decoration-4 decoration-[#2C2C2E]/10 hover:decoration-[#2C2C2E] transition-all break-all"
      >
        help@whispertranscriber.com
      </a>
    </div>
  </div>
</section>

---
const faqs = [
  {
    question: 'How does it work?',
    answer:
      'Hold a hotkey, speak, release. Your audio is transcribed locally on your Mac using AI (Whisper models) and the text is automatically pasted into the frontmost app.',
  },
  {
    question: 'Does it require internet?',
    answer:
      'No. After downloading the AI model once (142–574 MB), everything works 100% offline.',
  },
  {
    question: 'Is my data sent to any server?',
    answer:
      'Never. All processing happens locally on your Mac. The temporary audio file is deleted immediately after transcription.',
  },
  {
    question: 'Which languages are supported?',
    answer:
      '99 languages, including English, Spanish, Portuguese, French, German, Japanese, Chinese, and many more. You can select manually or use auto-detection.',
  },
  {
    question: 'Does it work with any app?',
    answer:
      'Yes. Whisper Transcriber uses the macOS Accessibility API to paste text into any app that has a Paste function — text editors, email, Slack, browsers, terminals, and more.',
  },
  {
    question: 'Is it compatible with Intel Macs?',
    answer:
      'No. Whisper Transcriber requires Apple Silicon (M1 or later) to run AI models locally via CoreML and Apple Neural Engine.',
  },
]
---

<section id="faq" class="py-32 bg-white">
  <div class="max-w-4xl mx-auto px-6">
    <div class="mb-24">
      <h2
        class="text-5xl md:text-7xl font-black text-[#2C2C2E] mb-8 tracking-tight"
      >
        Common <br /><span class="opacity-30">questions.</span>
      </h2>
    </div>

    <div class="space-y-12">
      {
        faqs.map((faq) => (
          <div class="group">
            <h3 class="text-2xl font-black text-[#2C2C2E] mb-4 tracking-tight group-hover:text-[#2C2C2E]/60 transition-colors cursor-pointer">
              {faq.question}
            </h3>
            <p class="text-[#2C2C2E]/60 font-medium leading-relaxed max-w-3xl">
              {faq.answer}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Support Section -->
    <div
      class="mt-40 p-12 bg-slate-50 rounded-[2.5rem] border border-[#2C2C2E]/5 text-center"
    >
      <h3 class="text-3xl font-black text-[#2C2C2E] mb-6 tracking-tight">
        Need more help?
      </h3>
      <p class="text-[#2C2C2E]/60 font-medium mb-10">
        We respond to all support emails within 24 hours.
      </p>
      <a
        href="mailto:help@whispertranscriber.com"
        class="text-xl font-black text-[#2C2C2E] underline underline-offset-8 decoration-4 decoration-[#2C2C2E]/10 hover:decoration-[#2C2C2E] transition-all"
      >
        help@whispertranscriber.com
      </a>
    </div>
  </div>
</section>

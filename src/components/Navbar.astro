---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const navLinks = [
  { href: '#features', label: t('nav.features') },
  { href: '#pricing', label: t('nav.pricing') },
  { href: '#faq', label: t('nav.faq') },
]
---

<header class="fixed top-0 left-0 right-0 z-50 bg-cream-100">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <div
        class="w-10 h-10 flex items-center justify-center transition-transform group-hover:scale-105"
      >
        <img
          src="/icon.png"
          alt="Whisper Transcriber Icon"
          class="w-full h-full object-contain mix-blend-multiply"
        />
      </div>
      <span class="text-xl font-bold tracking-tight text-[#2C2C2E]"
        >Whisper<span class="text-[#2C2C2E]/60">Transcriber</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-10">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-bold text-[#2C2C2E]/60 hover:text-[#2C2C2E] transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-4">
      <a
        href="#pricing"
        class="hidden sm:block bg-[#2C2C2E] text-white text-sm font-bold px-6 py-2.5 rounded-full hover:opacity-90 transition-all shadow-sm"
        >{t('nav.getStarted')}</a
      >

      <button id="mobile-menu-btn" class="md:hidden text-slate-600">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16m4 6h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden absolute top-20 left-0 right-0 bg-cream-100 border-b border-slate-100 p-6 shadow-lg z-50"
  >
    <nav class="flex flex-col gap-6">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-base font-bold text-[#2C2C2E]/80 hover:text-[#2C2C2E] transition-colors mobile-link"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="#pricing"
        class="text-base font-bold text-white bg-[#2C2C2E] text-center py-3 rounded-xl hover:opacity-90 transition-all sm:hidden mobile-link"
        >{t('nav.getStarted')}</a
      >
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  const links = document.querySelectorAll('.mobile-link')

  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden')
    })

    links.forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden')
      })
    })
  }
</script>

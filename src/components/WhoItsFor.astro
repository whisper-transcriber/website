---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const audiences = [
  {
    title: t('who.devs.title'),
    description: t('who.devs.desc'),
  },
  {
    title: t('who.writers.title'),
    description: t('who.writers.desc'),
  },
  {
    title: t('who.professionals.title'),
    description: t('who.professionals.desc'),
  },
  {
    title: t('who.students.title'),
    description: t('who.students.desc'),
  },
  {
    title: t('who.accessibility.title'),
    description: t('who.accessibility.desc'),
  },
  {
    title: t('who.multilingual.title'),
    description: t('who.multilingual.desc'),
  },
]
---

<section class="py-20 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 lg:mb-24">
      <h2
        class="text-4xl md:text-5xl lg:text-7xl font-black text-[#2C2C2E] mb-6 md:mb-8 tracking-tight"
        set:html={t('who.title')}
      >
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        audiences.map((item) => (
          <div class="p-8 lg:p-10 rounded-[2rem] lg:rounded-[2.5rem] bg-slate-50 border border-[#2C2C2E]/5 hover:bg-[#2C2C2E] hover:text-white transition-all duration-500 group">
            <h3 class="text-xl lg:text-2xl font-black mb-3 lg:mb-4 tracking-tight">
              {item.title}
            </h3>
            <p class="text-[#2C2C2E]/60 text-sm lg:text-base font-medium leading-relaxed group-hover:text-white/60 transition-colors">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

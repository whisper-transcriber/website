---
const audiences = [
  {
    title: 'Developers',
    description:
      'Dictate prompts for AI, write comments, PRs, and docs. Keep your focus on the logic.',
  },
  {
    title: 'Writers & Creators',
    description:
      'Capture ideas at the speed of thought. Dictate drafts and scripts effortlessly.',
  },
  {
    title: 'Professionals',
    description:
      'Emails, Slack, and reports—all 4x faster. Speak naturally and the text appears.',
  },
  {
    title: 'Students',
    description:
      'Take quick notes during lectures and transcribe thoughts for academic papers.',
  },
  {
    title: 'Accessibility',
    description:
      'Turn your voice into text effortlessly if typing is a struggle due to RSI or motor conditions.',
  },
  {
    title: 'Multilingual Users',
    description:
      'Switch between 99 languages with one click. Perfect for international teams.',
  },
]
---

<section class="py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-24">
      <h2
        class="text-5xl md:text-7xl font-black text-[#2C2C2E] mb-8 tracking-tight"
      >
        Built for <br /><span class="opacity-30">builders and thinkers.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        audiences.map((item) => (
          <div class="p-10 rounded-[2.5rem] bg-slate-50 border border-[#2C2C2E]/5 hover:bg-[#2C2C2E] hover:text-white transition-all duration-500 group">
            <h3 class="text-2xl font-black mb-4 tracking-tight">
              {item.title}
            </h3>
            <p class="text-[#2C2C2E]/60 font-medium leading-relaxed group-hover:text-white/60 transition-colors">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

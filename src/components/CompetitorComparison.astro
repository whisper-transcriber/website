---
---

<section class="py-32 bg-white overflow-x-auto">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-24">
      <h2
        class="text-5xl md:text-7xl font-black text-[#2C2C2E] mb-8 tracking-tight"
      >
        Why <span class="opacity-30">Whisper Transcriber?</span>
      </h2>
    </div>

    <div
      class="bg-white rounded-[2.5rem] border-2 border-[#2C2C2E] overflow-hidden"
    >
      <table class="w-full text-left border-collapse">
        <thead>
          <tr
            class="bg-[#2C2C2E] text-white text-[10px] font-black uppercase tracking-widest"
          >
            <th class="px-8 py-6">Feature</th>
            <th class="px-8 py-6">Whisper Transcriber</th>
            <th class="px-8 py-6 font-medium opacity-50">Competitors</th>
            <th class="px-8 py-6 font-medium opacity-50">Apple Dictation</th>
          </tr>
        </thead>
        <tbody class="text-[#2C2C2E] font-bold text-sm">
          <tr class="border-b border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px]"
              >Processing</td
            >
            <td class="px-8 py-6">100% Local</td>
            <td class="px-8 py-6 opacity-40">Cloud</td>
            <td class="px-8 py-6 opacity-40">Local (Limited)</td>
          </tr>
          <tr class="border-b border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px]"
              >Pricing</td
            >
            <td class="px-8 py-6">One-time payment</td>
            <td class="px-8 py-6 opacity-40">$12–25/mo</td>
            <td class="px-8 py-6 opacity-40">Free</td>
          </tr>
          <tr class="border-b border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px]"
              >Privacy</td
            >
            <td class="px-8 py-6 text-green-600">Total Privacy</td>
            <td class="px-8 py-6 opacity-40 italic">Data in cloud</td>
            <td class="px-8 py-6 opacity-40">Partial</td>
          </tr>
          <tr class="border-b border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px]"
              >Languages</td
            >
            <td class="px-8 py-6">99 (High Accuracy)</td>
            <td class="px-8 py-6 opacity-40">Varies</td>
            <td class="px-8 py-6 opacity-40">~60</td>
          </tr>
          <tr>
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px]"
              >Limits</td
            >
            <td class="px-8 py-6">Unlimited</td>
            <td class="px-8 py-6 opacity-40">Monthly caps</td>
            <td class="px-8 py-6 opacity-40">Unclear</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

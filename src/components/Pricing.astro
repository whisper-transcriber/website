---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const plans = [
  {
    name: t('pricing.free.name'),
    price: t('pricing.free.price'),
    description: t('pricing.free.desc'),
    features: [
      t('pricing.free.feat1'),
      t('pricing.free.feat2'),
      t('pricing.free.feat3'),
      t('pricing.free.feat4'),
      t('pricing.free.feat5'),
    ],
    cta: t('pricing.free.cta'),
    highlight: false,
    badge: '',
    id: 'free',
    link: 'https://api.whispertranscriber.com/download',
  },
  {
    name: t('pricing.paid.name'),
    price: t('pricing.paid.price'),
    description: t('pricing.paid.desc'),
    features: [
      t('pricing.paid.feat1'),
      t('pricing.paid.feat2'),
      t('pricing.paid.feat3'),
      t('pricing.paid.feat4'),
      t('pricing.paid.feat5'),
    ],
    cta: t('pricing.paid.cta'),
    highlight: true,
    badge: t('pricing.paid.badge'),
    id: 'paid',
    link: t('pricing.paid.link') as string,
  },
]
---

<section id="pricing" class="py-20 lg:py-32 bg-cream-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 lg:mb-20">
      <h2
        class="text-4xl md:text-5xl lg:text-7xl font-black text-brand-dark mb-6 tracking-tight"
        set:html={t('pricing.title')}
      >
      </h2>
      <p class="text-xl text-brand-dark/70 font-medium max-w-2xl mx-auto">
        {t('pricing.desc')}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-24">
      {
        plans.map((plan) => (
          <div
            class={`relative rounded-[2rem] lg:rounded-[2.5rem] p-8 lg:p-12 transition-all duration-300 ${
              plan.highlight
                ? 'bg-brand-dark text-white shadow-2xl lg:scale-105'
                : 'bg-cream-100 border border-brand-dark/5 text-brand-dark'
            }`}
          >
            <h3 class="text-2xl font-black mb-4 tracking-tight">{plan.name}</h3>
            <div class="flex items-baseline gap-1 mb-6">
              <span class="text-5xl font-black tracking-tight">
                {t('pricing.currency')}{plan.price}
              </span>
              {plan.price !== '0' && (
                <span
                  class={`text-sm font-bold uppercase tracking-widest ${
                    plan.highlight ? 'text-white/70' : 'text-brand-dark/70'
                  }`}
                >
                  {plan.badge}
                </span>
              )}
            </div>
            <p
              class={`mb-10 font-medium ${
                plan.highlight ? 'text-white/70' : 'text-brand-dark/70'
              }`}
            >
              {plan.description}
            </p>
            <ul class="space-y-4 mb-12">
              {plan.features.map((feature) => (
                <li class="flex items-center gap-3">
                  <svg
                    class="h-5 w-5 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="3"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  <span class="font-bold text-sm tracking-tight">
                    {feature}
                  </span>
                </li>
              ))}
            </ul>
            <a
              id={plan.id === 'free' ? 'trial-btn' : undefined}
              data-plan-id={plan.id}
              data-share-title={t('pricing.free.iosShareTitle')}
              data-share-btn={t('pricing.free.iosShareBtn')}
              data-share-text={t('pricing.free.iosShareText')}
              href={plan.link}
              class={`w-full py-5 rounded-2xl font-black text-center transition-all duration-300 block trial-btn-element ${
                plan.highlight
                  ? 'bg-cream-50 text-brand-dark hover:bg-slate-100'
                  : 'bg-brand-dark text-white hover:opacity-90'
              }`}
            >
              {plan.cta}
            </a>
          </div>
        ))
      }
    </div>

    <div
      class="max-w-3xl mx-auto text-center p-8 lg:p-12 bg-brand-dark/5 rounded-[2rem] lg:rounded-[2.5rem] border border-brand-dark/5"
    >
      <h3 class="text-2xl font-black text-brand-dark mb-4 tracking-tight">
        {t('pricing.why.title')}
      </h3>
      <p class="text-brand-dark/70 font-medium leading-relaxed">
        {t('pricing.why.desc')}
      </p>
    </div>
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    initShareButtons();
  });

  document.addEventListener('DOMContentLoaded', () => {
    initShareButtons();
  });

  function initShareButtons() {
    const isIOS = /iPhone|iPad|iPod/.test(navigator.userAgent);
    
    if (!isIOS || !navigator.share) return;

    const trialBtns = document.querySelectorAll('.trial-btn-element[data-plan-id="free"]');
    
    trialBtns.forEach(btn => {
      const shareTitle = btn.getAttribute('data-share-title') || 'Whisper Transcriber';
      const shareBtnText = btn.getAttribute('data-share-btn');
      const shareText = btn.getAttribute('data-share-text') || '';

      if (shareBtnText) btn.textContent = shareBtnText;
      
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        
        navigator.share({
          title: shareTitle,
          text: shareText,
          url: window.location.href
        }).catch(err => {
            console.log('Error sharing:', err);
        });
      });
    });
  }
</script>

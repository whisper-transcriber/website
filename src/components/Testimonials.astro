---
import { getLangFromUrl, useTranslations } from '../i18n/utils'
import { testimonialsEN, testimonialsPT } from '../data/testimonials'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

// Select the correct review dataset based on the current locale
const allTestimonials = lang === 'pt' ? testimonialsPT : testimonialsEN
---

<section
  id="testimonials"
  class="py-20 lg:py-32 bg-cream-50 relative overflow-hidden"
>
  <div class="max-w-7xl mx-auto px-6 relative z-10 mb-16 lg:mb-24">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto">
      <div
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#2C2C2E]/5 border border-[#2C2C2E]/10 text-[#2C2C2E]/80 text-[13px] font-bold mb-8 tracking-wide uppercase"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-4 h-4 text-brand-indigo/80"
        >
          <path
            d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"
          ></path>
        </svg>
        {t('testimonials.badge')}
      </div>

      <h2
        class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight mb-6 leading-[1.1]"
      >
        <Fragment set:html={t('testimonials.title')} />
      </h2>
      <p class="text-lg md:text-xl text-[#2C2C2E]/70 max-w-2xl mx-auto">
        {t('testimonials.subtitle')}
      </p>
    </div>
  </div>

  <div class="relative flex flex-col gap-8 overflow-hidden">
    <!-- Left Fade Gradient -->
    <div
      class="absolute inset-y-0 left-0 w-16 md:w-32 bg-gradient-to-r from-cream-50 to-transparent z-10 pointer-events-none"
    >
    </div>

    <!-- Single Marquee Row -->
    <div class="flex overflow-hidden w-full group py-4">
      <!-- Original List -->
      <div
        class="flex flex-shrink-0 animate-marquee gap-6 pr-6 min-w-full justify-around group-hover:[animation-play-state:paused]"
      >
        {
          allTestimonials.map((testimonial) => (
            <div class="w-[300px] md:w-[400px] flex-shrink-0">
              <div class="clean-card text-left flex flex-col h-full bg-white border-[#2C2C2E]/5 shadow-[0_4px_24px_-12px_rgba(0,0,0,0.06)] hover:shadow-[0_8px_32px_-12px_rgba(0,0,0,0.1)] transition-all duration-300">
                <p class="text-[#2C2C2E]/80 text-[15px] sm:text-base leading-relaxed mb-6 flex-grow">
                  "{testimonial.content}"
                </p>
                <div class="flex items-center gap-4 mt-auto pt-4 border-t border-[#2C2C2E]/5">
                  <img
                    src={testimonial.avatar}
                    alt={testimonial.name}
                    class="w-10 h-10 rounded-full object-cover bg-cream-100"
                    loading="lazy"
                  />
                  <div>
                    <h4 class="font-bold text-[#2C2C2E] text-sm">
                      {testimonial.name}
                    </h4>
                    <p class="text-[#2C2C2E]/50 text-xs font-medium">
                      {testimonial.role}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
      <!-- Duplicated List -->
      <div
        class="flex flex-shrink-0 animate-marquee gap-6 pr-6 min-w-full justify-around group-hover:[animation-play-state:paused]"
        aria-hidden="true"
      >
        {
          allTestimonials.map((testimonial) => (
            <div class="w-[300px] md:w-[400px] flex-shrink-0">
              <div class="clean-card text-left flex flex-col h-full bg-white border-[#2C2C2E]/5 shadow-[0_4px_24px_-12px_rgba(0,0,0,0.06)] hover:shadow-[0_8px_32px_-12px_rgba(0,0,0,0.1)] transition-all duration-300">
                <p class="text-[#2C2C2E]/80 text-[15px] sm:text-base leading-relaxed mb-6 flex-grow">
                  "{testimonial.content}"
                </p>
                <div class="flex items-center gap-4 mt-auto pt-4 border-t border-[#2C2C2E]/5">
                  <img
                    src={testimonial.avatar}
                    alt={testimonial.name}
                    class="w-10 h-10 rounded-full object-cover bg-cream-100"
                    loading="lazy"
                  />
                  <div>
                    <h4 class="font-bold text-[#2C2C2E] text-sm">
                      {testimonial.name}
                    </h4>
                    <p class="text-[#2C2C2E]/50 text-xs font-medium">
                      {testimonial.role}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Right Fade Gradient -->
    <div
      class="absolute inset-y-0 right-0 w-16 md:w-32 bg-gradient-to-l from-cream-50 to-transparent z-10 pointer-events-none"
    >
    </div>
  </div>
</section>

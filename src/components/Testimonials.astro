---
import { getLangFromUrl, useTranslations } from '../i18n/utils'
import { testimonialsEN, testimonialsPT } from '../data/testimonials'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

// Select the correct review dataset based on the current locale
const allTestimonials = lang === 'pt' ? testimonialsPT : testimonialsEN
---

<section
  id="testimonials"
  class="py-20 lg:py-32 bg-cream-50 relative overflow-hidden"
>
  <div class="max-w-7xl mx-auto px-6 relative z-10 mb-16 lg:mb-24">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto">
      <div
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-dark/5 border border-brand-dark/10 text-brand-dark/80 text-[13px] font-bold mb-8 tracking-wide uppercase"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-4 h-4 text-brand-indigo/80"
        >
          <path
            d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"
          ></path>
        </svg>
        {t('testimonials.badge')}
      </div>

      <h2
        class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight mb-6 leading-[1.1]"
      >
        <Fragment set:html={t('testimonials.title')} />
      </h2>
      <p class="text-lg md:text-xl text-brand-dark/70 max-w-2xl mx-auto">
        {t('testimonials.subtitle')}
      </p>
    </div>
  </div>

  <div class="relative flex flex-col gap-8 overflow-hidden">
    <!-- Left Fade Gradient -->
    <div
      class="absolute inset-y-0 left-0 w-16 md:w-32 bg-gradient-to-r from-cream-50 to-transparent z-10 pointer-events-none"
    >
    </div>

    <!-- Testimonials Track -->
    <div
      id="testimonials-track"
      class="flex overflow-x-auto w-full group py-4 gap-6 px-6 cursor-grab select-none [&::-webkit-scrollbar]:hidden"
      style="scrollbar-width: none; -ms-overflow-style: none; -webkit-overflow-scrolling: touch;"
    >
      {
        [...allTestimonials, ...allTestimonials].map((testimonial) => (
          <div class="w-[300px] md:w-[400px] flex-shrink-0 select-none pointer-events-none">
            <div class="clean-card text-left flex flex-col h-full bg-white border-brand-dark/5 shadow-[0_4px_24px_-12px_rgba(0,0,0,0.06)] transition-all duration-300 pointer-events-auto">
              <p class="text-brand-dark/80 text-[15px] sm:text-base leading-relaxed mb-6 flex-grow">
                "{testimonial.content}"
              </p>
              <div class="flex items-center gap-4 mt-auto pt-4 border-t border-brand-dark/5">
                <img
                  src={testimonial.avatar}
                  alt={testimonial.name}
                  class="w-10 h-10 rounded-full object-cover bg-cream-100"
                  loading="lazy"
                  draggable="false"
                />
                <div>
                  <h3 class="font-bold text-brand-dark text-sm">
                    {testimonial.name}
                  </h3>
                  <p class="text-brand-dark/50 text-xs font-medium">
                    {testimonial.role}
                  </p>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Right Fade Gradient -->
    <div
      class="absolute inset-y-0 right-0 w-16 md:w-32 bg-gradient-to-l from-cream-50 to-transparent z-10 pointer-events-none"
    >
    </div>
  </div>
</section>

<script>
  function initTestimonials() {
    const track = document.getElementById('testimonials-track') as HTMLElement
    if (!track) return
    if (track.hasAttribute('data-initialized')) return
    track.setAttribute('data-initialized', 'true')

    const items = track.children
    const halfCount = Math.floor(items.length / 2)
    if (halfCount === 0) return

    let isDown = false
    let startX = 0
    let scrollLeft = 0
    let isHovered = false
    let lastTime = 0
    let autoScrollSpeed = 60 // px per second

    // Auto-scroll loop using requestAnimationFrame for 60fps smoothness
    function autoScroll(timestamp: number) {
      if (!lastTime) lastTime = timestamp
      const deltaTime = timestamp - lastTime
      lastTime = timestamp

      // Only animate if the user isn't hovering or dragging
      if (!isDown && !isHovered) {
        track.scrollLeft += (autoScrollSpeed / 1000) * deltaTime
      }

      checkInfiniteScroll()
      requestAnimationFrame(autoScroll)
    }

    // Keep it infinite natively
    function checkInfiniteScroll() {
      if (!items[halfCount] || !items[0]) return

      const halfEl = items[halfCount] as HTMLElement
      const firstEl = items[0] as HTMLElement
      // Calculate exact halfway position preserving dynamic gaps
      const halfwayPoint = halfEl.offsetLeft - firstEl.offsetLeft

      if (track.scrollLeft >= halfwayPoint) {
        track.scrollLeft -= halfwayPoint // Reset seamless
      } else if (track.scrollLeft <= 0) {
        // If they drag heavily to the left past the start, jump to midway
        track.scrollLeft += halfwayPoint
      }
    }

    // --- MOUSE DRAG LOGIC ---
    track.addEventListener('mousedown', (e) => {
      isDown = true
      track.classList.add('cursor-grabbing')
      startX = e.pageX - track.offsetLeft
      scrollLeft = track.scrollLeft
    })

    track.addEventListener('mouseleave', () => {
      isDown = false
      isHovered = false
      track.classList.remove('cursor-grabbing')
    })

    track.addEventListener('mouseup', () => {
      isDown = false
      track.classList.remove('cursor-grabbing')
    })

    track.addEventListener('mousemove', (e) => {
      if (!isDown) return
      e.preventDefault() // Prevents image/text native browser dragging behavior
      const x = e.pageX - track.offsetLeft
      // Multiplier increases manual scroll speed
      const walk = (x - startX) * 2 // Increased drag multiplier to 2 for better feel
      track.scrollLeft = scrollLeft - walk
    })

    // --- HOVER PAUSE ---
    track.addEventListener('mouseenter', () => {
      isHovered = true
    })

    // --- NATIVE TOUCH ---
    // Touch device users rely on native overflow scroll.
    // We bind a scroll listener to monitor bounds.
    track.addEventListener('scroll', () => {
      if (!isDown) {
        // Prevent check collision with manual mouse move
        checkInfiniteScroll()
      }
    })

    // Start auto scroll
    requestAnimationFrame(autoScroll)
  }

  // Bind to Astro's view transitions or standard load
  document.addEventListener('astro:page-load', initTestimonials)

  // Also run immediately just in case (Astro sometimes needs this for first load)
  if (
    document.readyState === 'complete' ||
    document.readyState === 'interactive'
  ) {
    initTestimonials()
  } else {
    document.addEventListener('DOMContentLoaded', initTestimonials)
  }
</script>

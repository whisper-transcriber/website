---
import Layout from '../layouts/Layout.astro'
import Navbar from './Navbar.astro'
import Footer from './Footer.astro'
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const home = lang === 'br' ? '/br/' : '/'
---

<Layout title={`${t('pp.title')} - Whisper Transcriber`} description={t('pp.meta')}>
  <Navbar />
  <main class="bg-white min-h-screen">
    <div class="max-w-3xl mx-auto px-6 py-20 lg:py-28">
      <a href={home} class="inline-flex items-center gap-1.5 text-sm text-brand-dark/50 hover:text-brand-dark transition-colors mb-10">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        {t('pp.back')}
      </a>

      <h1 class="text-4xl md:text-5xl font-bold font-display text-brand-dark mb-4">
        {t('pp.title')}
      </h1>
      <p class="text-brand-dark/50 text-sm mb-12">
        {t('pp.lastUpdated')}
      </p>

      <div class="prose prose-lg max-w-none text-brand-dark/80 [&_h2]:text-brand-dark [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:mt-12 [&_h2]:mb-4 [&_p]:mb-4 [&_p]:leading-relaxed [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:pl-6 [&_li]:mb-2 [&_strong]:text-brand-dark [&_a]:text-brand-dark [&_a]:underline [&_a]:underline-offset-2">
        <p>{t('pp.intro')}</p>

        <h2>{t('pp.s1.title')}</h2>
        <p>{t('pp.s1.p1')}</p>
        <ul>
          <li>{t('pp.s1.li1')}</li>
          <li>{t('pp.s1.li2')}</li>
          <li>{t('pp.s1.li3')}</li>
        </ul>

        <h2>{t('pp.s2.title')}</h2>
        <p>{t('pp.s2.p1')}</p>
        <ul>
          <li>{t('pp.s2.li1')}</li>
          <li>{t('pp.s2.li2')}</li>
          <li>{t('pp.s2.li3')}</li>
          <li>{t('pp.s2.li4')}</li>
        </ul>
        <p>{t('pp.s2.p2')}</p>

        <h2>{t('pp.s3.title')}</h2>
        <p>{t('pp.s3.p1')}</p>

        <h2>{t('pp.s4.title')}</h2>
        <p>{t('pp.s4a.p1')}</p>
        <ul>
          <li set:html={t('pp.s4a.li1')} />
          <li set:html={t('pp.s4a.li2')} />
          <li set:html={t('pp.s4a.li3')} />
          <li set:html={t('pp.s4a.li4')} />
        </ul>
        <p>{t('pp.s4a.p2')}</p>

        <h2>{t('pp.s5.title')}</h2>
        <p>{t('pp.s5.p1')}</p>
        <ul>
          <li>{t('pp.s5.li1')}</li>
          <li>{t('pp.s5.li2')}</li>
          <li>{t('pp.s5.li3')}</li>
        </ul>

        <h2>{t('pp.s6.title')}</h2>
        <p>{t('pp.s6.p1')}</p>

        <h2>{t('pp.s7.title')}</h2>
        <p>{t('pp.s7.p1')}</p>

        <h2>{t('pp.s8.title')}</h2>
        <p>{t('pp.s8.p1')}</p>

        <h2>{t('pp.s9.title')}</h2>
        <p set:html={t('pp.s9.p1')} />
      </div>
    </div>
  </main>
  <Footer />
</Layout>

---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<section class="py-32 bg-slate-50">
  <div class="max-w-5xl mx-auto px-6">
    <div class="max-w-2xl mb-24">
      <h2
        class="text-5xl md:text-7xl font-black text-[#2C2C2E] mb-8 tracking-tight"
        set:html={t('privacy.title')}
      >
      </h2>
      <p class="text-xl text-[#2C2C2E]/60 font-medium leading-relaxed">
        {t('privacy.desc')}
      </p>
    </div>

    <div
      class="bg-white rounded-[2.5rem] border border-[#2C2C2E]/5 overflow-hidden shadow-xl"
    >
      <table class="w-full text-left border-collapse">
        <thead>
          <tr
            class="bg-[#2C2C2E]/5 text-[10px] font-black uppercase tracking-widest text-[#2C2C2E]/40"
          >
            <th class="px-8 py-6">{t('privacy.table.header1')}</th>
            <th class="px-8 py-6 text-[#2C2C2E]"
              >{t('privacy.table.header2')}</th
            >
            <th class="px-8 py-6">{t('privacy.table.header3')}</th>
          </tr>
        </thead>
        <tbody class="text-[#2C2C2E] font-bold text-base">
          <tr class="border-t border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px] tracking-widest"
              >{t('privacy.row1.label')}</td
            >
            <td class="px-8 py-6">{t('privacy.row1.whisper')}</td>
            <td class="px-8 py-6 opacity-40">{t('privacy.row1.cloud')}</td>
          </tr>
          <tr class="border-t border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px] tracking-widest"
              >{t('privacy.row2.label')}</td
            >
            <td class="px-8 py-6 text-green-600">{t('privacy.row2.whisper')}</td
            >
            <td class="px-8 py-6 opacity-40">{t('privacy.row2.cloud')}</td>
          </tr>
          <tr class="border-t border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px] tracking-widest"
              >{t('privacy.row3.label')}</td
            >
            <td class="px-8 py-6">{t('privacy.row3.whisper')}</td>
            <td class="px-8 py-6 opacity-40">{t('privacy.row3.cloud')}</td>
          </tr>
          <tr class="border-t border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px] tracking-widest"
              >{t('privacy.row4.label')}</td
            >
            <td class="px-8 py-6 text-green-600">{t('privacy.row4.whisper')}</td
            >
            <td class="px-8 py-6 opacity-40">{t('privacy.row4.cloud')}</td>
          </tr>
          <tr class="border-t border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px] tracking-widest"
              >{t('privacy.row5.label')}</td
            >
            <td class="px-8 py-6">{t('privacy.row5.whisper')}</td>
            <td class="px-8 py-6 opacity-40">{t('privacy.row5.cloud')}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="mt-12 text-center p-8 rounded-3xl bg-[#2C2C2E] text-white">
      <p class="text-xl font-bold tracking-tight">
        {t('privacy.quote')}
      </p>
    </div>
  </div>
</section>

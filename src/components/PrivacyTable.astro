---
---

<section class="py-32 bg-slate-50">
  <div class="max-w-5xl mx-auto px-6">
    <div class="max-w-2xl mb-24">
      <h2
        class="text-5xl md:text-7xl font-black text-[#2C2C2E] mb-8 tracking-tight"
      >
        Designed for <br /><span class="opacity-50">privacy from day one.</span>
      </h2>
      <p class="text-xl text-[#2C2C2E]/60 font-medium leading-relaxed">
        Your voice is personal. We treat it that way. Recorded audio is
        transcribed locally and deleted immediately after.
      </p>
    </div>

    <div
      class="bg-white rounded-[2.5rem] border border-[#2C2C2E]/5 overflow-hidden shadow-xl"
    >
      <table class="w-full text-left border-collapse">
        <thead>
          <tr
            class="bg-[#2C2C2E]/5 text-[10px] font-black uppercase tracking-widest text-[#2C2C2E]/40"
          >
            <th class="px-8 py-6">Security Check</th>
            <th class="px-8 py-6 text-[#2C2C2E]">Whisper Transcriber</th>
            <th class="px-8 py-6">Cloud Competitors</th>
          </tr>
        </thead>
        <tbody class="text-[#2C2C2E] font-bold text-base">
          <tr class="border-t border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px] tracking-widest"
              >Audio Processing</td
            >
            <td class="px-8 py-6">On your Mac (Final)</td>
            <td class="px-8 py-6 opacity-40">Remote servers</td>
          </tr>
          <tr class="border-t border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px] tracking-widest"
              >Audio Sent to Servers</td
            >
            <td class="px-8 py-6 text-green-600">Never</td>
            <td class="px-8 py-6 opacity-40">Yes (Every time)</td>
          </tr>
          <tr class="border-t border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px] tracking-widest"
              >Works Offline</td
            >
            <td class="px-8 py-6">Yes, 100%</td>
            <td class="px-8 py-6 opacity-40">No</td>
          </tr>
          <tr class="border-t border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px] tracking-widest"
              >Training on Data</td
            >
            <td class="px-8 py-6 text-green-600">Never</td>
            <td class="px-8 py-6 opacity-40">Possibly</td>
          </tr>
          <tr class="border-t border-[#2C2C2E]/5">
            <td
              class="px-8 py-6 text-[#2C2C2E]/40 font-black uppercase text-[10px] tracking-widest"
              >Storage</td
            >
            <td class="px-8 py-6">Temporary (Auto-delete)</td>
            <td class="px-8 py-6 opacity-40">Indefinite</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="mt-12 text-center p-8 rounded-3xl bg-[#2C2C2E] text-white">
      <p class="text-xl font-bold tracking-tight">
        "While others process audio in the cloud, we process everything on your
        Mac's chip."
      </p>
    </div>
  </div>
</section>

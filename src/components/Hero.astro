---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<section class="pt-32 pb-16 lg:pt-40 lg:pb-20 bg-white">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <div
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-slate-50 border border-slate-100 text-[#2C2C2E]/60 text-[13px] font-bold mb-10 tracking-wide uppercase"
    >
      {t('hero.badge')}
    </div>

    <h1
      class="text-5xl md:text-6xl lg:text-7xl font-black tracking-tight text-[#2C2C2E] mb-6 md:mb-8 leading-[1.1]"
    >
      {t('hero.title')}
    </h1>

    <p
      class="text-lg md:text-xl lg:text-2xl text-[#2C2C2E]/60 mb-10 md:mb-12 max-w-4xl mx-auto font-medium leading-relaxed"
    >
      {t('hero.description')}
    </p>

    <div
      class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-4 sm:gap-5 mb-12 md:mb-16"
    >
      <a
        href="https://api.whispertranscriber.com/download"
        class="btn-brand-primary flex-1 sm:flex-none text-lg px-8 sm:px-12 py-4 sm:py-5 shadow-xl flex items-center justify-center gap-3"
      >
        <svg
          viewBox="0 0 39 44"
          class="w-8 h-8 fill-current"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M19.8196726,13.1384615 C20.902953,13.1384615 22.2608678,12.406103 23.0695137,11.4296249 C23.8018722,10.5446917 24.3358837,9.30883662 24.3358837,8.07298156 C24.3358837,7.9051494 24.3206262,7.73731723 24.2901113,7.6 C23.0847711,7.64577241 21.6353115,8.4086459 20.7656357,9.43089638 C20.0790496,10.2090273 19.4534933,11.4296249 19.4534933,12.6807374 C19.4534933,12.8638271 19.4840083,13.0469167 19.4992657,13.1079466 C19.5755531,13.1232041 19.6976128,13.1384615 19.8196726,13.1384615 Z M16.0053051,31.6 C17.4852797,31.6 18.1413509,30.6082645 19.9875048,30.6082645 C21.8641736,30.6082645 22.2761252,31.5694851 23.923932,31.5694851 C25.5412238,31.5694851 26.6245041,30.074253 27.6467546,28.6095359 C28.7910648,26.9312142 29.2640464,25.2834075 29.2945613,25.2071202 C29.1877591,25.1766052 26.0904927,23.9102352 26.0904927,20.3552448 C26.0904927,17.2732359 28.5316879,15.8848061 28.6690051,15.7780038 C27.0517133,13.4588684 24.5952606,13.3978385 23.923932,13.3978385 C22.1082931,13.3978385 20.6283185,14.4963764 19.6976128,14.4963764 C18.6906198,14.4963764 17.36322,13.4588684 15.7917006,13.4588684 C12.8012365,13.4588684 9.765,15.9305785 9.765,20.5993643 C9.765,23.4982835 10.8940528,26.565035 12.2824825,28.548506 C13.4725652,30.2268277 14.5100731,31.6 16.0053051,31.6 Z"
          ></path>
        </svg>
        {t('hero.download')}
      </a>
    </div>

    <!-- Badges -->
    <div
      class="flex flex-wrap justify-center gap-x-4 sm:gap-x-8 gap-y-3 sm:gap-y-4 mb-16 lg:mb-24 opacity-40"
    >
      <div
        class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#2C2C2E]"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        {t('hero.badge.silicon')}
      </div>
      <div
        class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#2C2C2E]"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        {t('hero.badge.macos')}
      </div>
      <div
        class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#2C2C2E]"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        {t('hero.badge.offline')}
      </div>
      <div
        class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#2C2C2E]"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        {t('hero.badge.privacy')}
      </div>
    </div>

    <!-- App Preview Container -->
    <div class="relative max-w-5xl mx-auto">
      <div class="absolute inset-0 bg-[#2C2C2E]/5 blur-3xl rounded-full -z-10">
      </div>
      <div
        class="bg-white border-4 md:border-8 border-[#2C2C2E]/5 rounded-[2rem] md:rounded-[2.5rem] shadow-[0_32px_64px_-12px_rgba(0,0,0,0.1)] overflow-hidden"
      >
        <div
          class="aspect-[4/3] md:aspect-[16/10] bg-[#2C2C2E]/5 flex items-center justify-center p-6 md:p-12"
        >
          <div
            class="w-full h-full bg-white rounded-2xl shadow-sm flex flex-col p-10 text-left"
          >
            <div class="flex items-center gap-3 mb-8">
              <div
                class="w-10 h-10 rounded-full bg-[#2C2C2E] flex items-center justify-center"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6 text-white"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"
                  ></path>
                </svg>
              </div>
              <div class="h-4 w-32 bg-[#2C2C2E]/10 rounded-full"></div>
            </div>
            <div class="space-y-4">
              <div class="h-5 w-full bg-[#2C2C2E]/5 rounded-lg"></div>
              <div class="h-5 w-[90%] bg-[#2C2C2E]/5 rounded-lg"></div>
              <div class="h-5 w-[95%] bg-[#2C2C2E]/5 rounded-lg"></div>
              <div
                class="h-5 w-[80%] bg-[#2C2C2E]/10 rounded-lg border-l-4 border-[#2C2C2E]"
              >
              </div>
            </div>
            <div
              class="mt-auto flex justify-between items-center text-[#2C2C2E]/20"
            >
              <div class="flex gap-2">
                <div class="w-6 h-6 rounded bg-[#2C2C2E]/5"></div>
                <div class="w-6 h-6 rounded bg-[#2C2C2E]/5"></div>
              </div>
              <div class="text-xs font-bold font-mono">
                {t('hero.preview.flowActive')}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

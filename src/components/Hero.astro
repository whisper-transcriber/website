---
import { getLangFromUrl, useTranslations } from '../i18n/utils'
import DownloadButton from './DownloadButton.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<section class="min-h-screen flex items-center pt-20 pb-12 bg-cream-100">
  <div class="max-w-5xl mx-auto px-6 text-center w-full">
    <div
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-muted/10 border border-brand-muted/20 text-brand-dark/80 text-[13px] font-bold mb-10 tracking-wide uppercase"
    >
      {t('hero.badge')}
    </div>

    <h1
      class="text-5xl md:text-6xl lg:text-7xl font-black tracking-tight text-brand-dark mb-6 md:mb-8 leading-[1.1]"
    >
      {t('hero.title')}
    </h1>

    <p
      class="text-lg md:text-xl lg:text-2xl text-brand-dark/70 mb-10 md:mb-12 max-w-4xl mx-auto font-medium leading-relaxed"
    >
      {t('hero.description')}
    </p>

    <div
      class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-4 sm:gap-5 mb-12 md:mb-16"
    >
      <DownloadButton label={t('hero.download') as string} />
    </div>

    <!-- Badges -->
    <div
      class="flex flex-wrap justify-center gap-x-4 sm:gap-x-8 gap-y-3 sm:gap-y-4 mb-16 lg:mb-24 opacity-70"
    >
      <div
        class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-brand-dark"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        {t('hero.badge.silicon')}
      </div>
      <div
        class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-brand-dark"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        {t('hero.badge.macos')}
      </div>
      <div
        class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-brand-dark"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        {t('hero.badge.offline')}
      </div>
      <div
        class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-brand-dark"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        {t('hero.badge.privacy')}
      </div>
    </div>
  </div>
</section>

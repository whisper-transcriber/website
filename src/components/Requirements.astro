---
---

<section class="py-32 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      <!-- System Requirements -->
      <div>
        <h2 class="text-4xl font-black text-[#2C2C2E] mb-12 tracking-tight">
          System Requirements
        </h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-xl bg-white flex items-center justify-center shrink-0 shadow-sm border border-[#2C2C2E]/5"
            >
              <span class="font-black text-sm">OS</span>
            </div>
            <div>
              <p class="font-bold text-[#2C2C2E]">
                macOS 14.0 (Sonoma) or later
              </p>
              <p class="text-sm text-[#2C2C2E]/60">
                Built for the latest macOS features.
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-xl bg-white flex items-center justify-center shrink-0 shadow-sm border border-[#2C2C2E]/5"
            >
              <span class="font-black text-sm">CPU</span>
            </div>
            <div>
              <p class="font-bold text-[#2C2C2E]">Apple Silicon Required</p>
              <p class="text-sm text-[#2C2C2E]/60">
                Requires M1, M2, M3, or M4 chips for local AI.
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-xl bg-white flex items-center justify-center shrink-0 shadow-sm border border-[#2C2C2E]/5"
            >
              <span class="font-black text-sm">RAM</span>
            </div>
            <div>
              <p class="font-bold text-[#2C2C2E]">500 MB – 1.5 GB Free</p>
              <p class="text-sm text-[#2C2C2E]/60">
                Depending on the chosen model accuracy.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Permissions -->
      <div>
        <h2 class="text-4xl font-black text-[#2C2C2E] mb-12 tracking-tight">
          Three Permissions
        </h2>
        <div
          class="bg-white rounded-[2.5rem] p-10 border border-[#2C2C2E]/5 shadow-sm"
        >
          <ul class="space-y-8">
            <li class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
                <span class="font-bold">Microphone</span>
              </div>
              <span
                class="text-xs font-black uppercase text-[#2C2C2E]/30 tracking-widest"
                >To Record</span
              >
            </li>
            <li class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
                <span class="font-bold">Accessibility</span>
              </div>
              <span
                class="text-xs font-black uppercase text-[#2C2C2E]/30 tracking-widest"
                >To Paste</span
              >
            </li>
            <li class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
                <span class="font-bold">Input Monitoring</span>
              </div>
              <span
                class="text-xs font-black uppercase text-[#2C2C2E]/30 tracking-widest"
                >To Listen</span
              >
            </li>
          </ul>
          <div
            class="mt-8 pt-8 border-t border-[#2C2C2E]/5 text-sm text-[#2C2C2E]/40 font-medium italic"
          >
            "Zero cloud concerns. We only ask for what's needed to run natively
            on your Mac."
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

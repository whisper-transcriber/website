---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<section class="py-20 lg:py-32 bg-cream-100">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16">
      <!-- System Requirements -->
      <div>
        <h2
          class="text-3xl lg:text-4xl font-black text-brand-dark mb-8 lg:mb-12 tracking-tight"
        >
          {t('req.sys.title')}
        </h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-xl bg-cream-50 flex items-center justify-center shrink-0 shadow-sm border border-brand-dark/5"
            >
              <span class="font-black text-sm">{t('req.sys.os.label')}</span>
            </div>
            <div>
              <p class="font-bold text-brand-dark">
                {t('req.sys.os.value')}
              </p>
              <p class="text-sm text-brand-dark/70">
                {t('req.sys.os.desc')}
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-xl bg-cream-50 flex items-center justify-center shrink-0 shadow-sm border border-brand-dark/5"
            >
              <span class="font-black text-sm">{t('req.sys.cpu.label')}</span>
            </div>
            <div>
              <p class="font-bold text-brand-dark">{t('req.sys.cpu.value')}</p>
              <p class="text-sm text-brand-dark/70">
                {t('req.sys.cpu.desc')}
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-xl bg-cream-50 flex items-center justify-center shrink-0 shadow-sm border border-brand-dark/5"
            >
              <span class="font-black text-sm">{t('req.sys.ram.label')}</span>
            </div>
            <div>
              <p class="font-bold text-brand-dark">{t('req.sys.ram.value')}</p>
              <p class="text-sm text-brand-dark/70">
                {t('req.sys.ram.desc')}
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Permissions -->
      <div>
        <h2
          class="text-3xl lg:text-4xl font-black text-brand-dark mb-8 lg:mb-12 tracking-tight"
        >
          {t('req.perm.title')}
        </h2>
        <div
          class="bg-cream-50 rounded-[2rem] lg:rounded-[2.5rem] p-6 text-sm md:text-base lg:p-10 border border-brand-dark/5 shadow-sm"
        >
          <ul class="space-y-8">
            <li class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
                <span class="font-bold">{t('req.perm.mic')}</span>
              </div>
              <span
                class="text-xs font-black uppercase text-brand-dark/70 tracking-widest"
                >{t('req.perm.mic.desc')}</span
              >
            </li>
            <li class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
                <span class="font-bold">{t('req.perm.acc')}</span>
              </div>
              <span
                class="text-xs font-black uppercase text-brand-dark/70 tracking-widest"
                >{t('req.perm.acc.desc')}</span
              >
            </li>
            <li class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
                <span class="font-bold">{t('req.perm.monitor')}</span>
              </div>
              <span
                class="text-xs font-black uppercase text-brand-dark/70 tracking-widest"
                >{t('req.perm.monitor.desc')}</span
              >
            </li>
          </ul>
          <div
            class="mt-8 pt-8 border-t border-brand-dark/5 text-sm text-brand-dark/70 font-medium italic"
          >
            {t('req.perm.quote')}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

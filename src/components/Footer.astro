---
import { getLangFromUrl, useTranslations } from '../i18n/utils'
const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const privacyHref = lang === 'br' ? '/br/privacy' : '/privacy'
---

<footer class="bg-cream-50 border-t border-brand-dark/5 py-12">
  <div class="max-w-7xl mx-auto px-6 flex flex-col items-center gap-6">
    <div class="flex items-center gap-2">
      <div class="w-10 h-10 flex items-center justify-center">
        <img
          src="/icon.png"
          alt="Whisper Transcriber Icon"
          class="w-full h-full object-contain"
        />
      </div>
      <span class="text-xl font-black tracking-tight text-brand-dark">
        Whisper<span class="text-brand-dark/70">Transcriber</span>
      </span>
    </div>
    <div class="flex flex-wrap justify-center gap-x-6 gap-y-2">
      <span class="flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-brand-dark/40">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        {t('hero.badge.silicon')}
      </span>
      <span class="flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-brand-dark/40">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        {t('hero.badge.macos')}
      </span>
      <span class="flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-brand-dark/40">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        {t('hero.badge.offline')}
      </span>
      <span class="flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-brand-dark/40">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        {t('hero.badge.privacy')}
      </span>
    </div>
    <a href={privacyHref} class="text-xs text-brand-dark/30 hover:text-brand-dark/60 transition-colors">
      {t('pp.title')}
    </a>
  </div>
</footer>

---
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<footer class="bg-white border-t border-[#2C2C2E]/5 py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-24 max-w-4xl mx-auto">
      <div>
        <div class="flex items-center gap-2 mb-8">
          <div
            class="w-8 h-8 rounded-lg bg-[#2C2C2E] flex items-center justify-center"
          >
            <div class="w-4 h-1 bg-white rounded-full"></div>
          </div>
          <span class="text-xl font-black tracking-tighter text-[#2C2C2E]"
            >Whisper <span class="opacity-30">Transcriber</span>
          </span>
        </div>
        <p class="text-[#2C2C2E]/60 font-medium leading-relaxed max-w-xs mb-6">
          100% local voice-to-text for your Mac.<br />
          No cloud, no subscription, no limits.
        </p>
        <div class="flex flex-col gap-2 text-sm font-bold text-[#2C2C2E]/80">
          <a href="#pricing" class="hover:text-[#2C2C2E]">Pricing</a>
          <a
            href="https://api.whispertranscriber.com/download"
            class="hover:text-[#2C2C2E]">Download</a
          >
        </div>
      </div>
      <div class="md:text-right flex flex-col items-start md:items-end">
        <div
          class="text-xs font-black uppercase tracking-widest text-[#2C2C2E] mb-8"
        >
          Company
        </div>
        <div
          class="flex flex-col gap-4 text-sm font-bold text-[#2C2C2E]/60 md:items-end"
        >
          <a href="#" class="hover:text-[#2C2C2E]">{t('footer.about')}</a>
          <a href="#" class="hover:text-[#2C2C2E]">{t('footer.blog')}</a>
          <a href="#" class="hover:text-[#2C2C2E]">{t('footer.privacy')}</a>
        </div>
      </div>
    </div>
  </div>

  <div
    class="flex flex-col md:flex-row justify-between items-center pt-12 border-t border-[#2C2C2E]/5 gap-6"
  >
    <div
      class="text-sm font-bold text-[#2C2C2E]/20"
      set:html={t('footer.copyright')}
    >
    </div>
    <div class="flex gap-8 text-sm font-bold text-[#2C2C2E]/20">
      <a href="#" class="hover:text-[#2C2C2E]">Twitter</a>
      <a href="#" class="hover:text-[#2C2C2E]">LinkedIn</a>
      <a href="#" class="hover:text-[#2C2C2E]">Discord</a>
    </div>
  </div>
</footer>

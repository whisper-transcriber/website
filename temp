<script>
  // Simple vanilla JS to handle the active states and video switching
  const CDN_URL = "https://seu-bucket-cloudflare.com"; // Keep in sync with Astro frontmatter
  const lang = document.documentElement.lang || "en"; // Get current language from HTML

  function setupTabs1() {
    const tabs = document.querySelectorAll(".feature-tab-1");
    const videoPlayer = document.getElementById(
      "video-player-1",
    ) as HTMLVideoElement;
    const loader = document.getElementById("video-loader-1");

    if (!tabs.length || !videoPlayer || !loader) return;

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        // Update tab styles
        tabs.forEach((t) => {
          t.className =
            "feature-tab-1 text-left p-5 md:p-6 rounded-2xl border-2 transition-all duration-300 w-full group flex-1 flex flex-col justify-center mb-3 last:mb-0 border-transparent bg-transparent hover:bg-[#2C2C2E]/5 hover:border-[#2C2C2E]/10";
          const h3 = t.querySelector("h3");
          const p = t.querySelector("p");
          if (h3)
            h3.className =
              "text-xl font-bold mb-2 transition-colors duration-300 text-[#2C2C2E]/60 group-hover:text-[#2C2C2E]";
          if (p)
            p.className =
              "text-[15px] leading-relaxed transition-colors duration-300 text-[#2C2C2E]/50 group-hover:text-[#2C2C2E]/70";
        });

        tab.className =
          "feature-tab-1 text-left p-5 md:p-6 rounded-2xl border-2 transition-all duration-300 w-full group flex-1 flex flex-col justify-center mb-3 last:mb-0 border-[#2C2C2E] bg-white shadow-[0_8px_32px_-12px_rgba(0,0,0,0.1)]";
        const h3 = tab.querySelector("h3");
        const p = tab.querySelector("p");
        if (h3)
          h3.className =
            "text-xl font-bold mb-2 transition-colors duration-300 text-[#2C2C2E]";
        if (p)
          p.className =
            "text-[15px] leading-relaxed transition-colors duration-300 text-[#2C2C2E]/80";

        // Handle Video Switch
        const videoKey = tab.getAttribute("data-videokey");
        if (videoKey && !videoPlayer.src.includes(videoKey)) {
          // Show loader and hide old video smoothly
          loader.classList.remove("opacity-0");
          videoPlayer.classList.add("opacity-0");

          // Small timeout to allow fade out before swapping src
          setTimeout(() => {
            videoPlayer.src = `${CDN_URL}/${videoKey}-${lang}.mp4`;
            videoPlayer
              .play()
              .catch((e) => console.log("Autoplay prevented:", e));
          }, 300);
        }
      });
    });
  }

  function setupTabs2() {
    const tabs = document.querySelectorAll(".feature-tab-2");
    const videoPlayer = document.getElementById(
      "video-player-2",
    ) as HTMLVideoElement;
    const loader = document.getElementById("video-loader-2");

    if (!tabs.length || !videoPlayer || !loader) return;

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        tabs.forEach((t) => {
          t.className =
            "feature-tab-2 text-left p-5 md:p-6 rounded-2xl border-2 transition-all duration-300 w-full group flex-1 flex flex-col justify-center mb-3 last:mb-0 border-transparent bg-transparent hover:bg-[#2C2C2E]/5 hover:border-[#2C2C2E]/10";
          const h3 = t.querySelector("h3");
          const p = t.querySelector("p");
          if (h3)
            h3.className =
              "text-xl font-bold mb-2 transition-colors duration-300 text-[#2C2C2E]/60 group-hover:text-[#2C2C2E]";
          if (p)
            p.className =
              "text-[15px] leading-relaxed transition-colors duration-300 text-[#2C2C2E]/50 group-hover:text-[#2C2C2E]/70";
        });

        tab.className =
          "feature-tab-2 text-left p-5 md:p-6 rounded-2xl border-2 transition-all duration-300 w-full group flex-1 flex flex-col justify-center mb-3 last:mb-0 border-[#2C2C2E] bg-white shadow-[0_8px_32px_-12px_rgba(0,0,0,0.1)]";
        const h3 = tab.querySelector("h3");
        const p = tab.querySelector("p");
        if (h3)
          h3.className =
            "text-xl font-bold mb-2 transition-colors duration-300 text-[#2C2C2E]";
        if (p)
          p.className =
            "text-[15px] leading-relaxed transition-colors duration-300 text-[#2C2C2E]/80";

        const videoKey = tab.getAttribute("data-videokey");
        if (videoKey && !videoPlayer.src.includes(videoKey)) {
          loader.classList.remove("opacity-0");
          videoPlayer.classList.add("opacity-0");
          setTimeout(() => {
            videoPlayer.src = `${CDN_URL}/${videoKey}-${lang}.mp4`;
            videoPlayer
              .play()
              .catch((e) => console.log("Autoplay prevented:", e));
          }, 300);
        }
      });
    });
  }

  function init() {
    setupTabs1();
    setupTabs2();
  }

  // Run on load and after Astro page transitions
  init();
  document.addEventListener("astro:page-load", init);
</script>
